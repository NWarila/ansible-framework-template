C4Context
  title ansible-framework-template — system context

  Person(maintainer, "Framework Maintainer", "Develops and releases the Ansible framework.")

  System_Boundary(framework, "ansible-framework-template") {
    System(reusable_wf, "reusable-ansible-framework-run.yaml", "Reusable GitHub Actions workflow: overlay, install, lint, syntax-check, playbook run, release evidence.")
    System(roles, "ansible/roles/", "Baseline role (evidence) and example_nginx role (canonical role-loader pattern).")
    System(tooling, "tools/verify.py + policies/", "Local quality gates: ansible-lint, OPA, ADR schema, docs layout, manifest check.")
  }

  System_Ext(terraform_caller, "Terraform Repo", "Calls reusable-ansible-framework-run.yaml after infrastructure is provisioned. Overlays caller vars/inventory.")
  System_Ext(packer_caller, "Packer Repo", "Calls reusable-ansible-framework-run.yaml during image build. Overlays image-specific vars.")
  System_Ext(consumer_role, "Derivative Framework", "Forks or templates from this repo. Inherits baseline-manifest.json byte-identical files.")
  System_Ext(github_actions, "GitHub Actions CI", "Runs ci.yaml, security.yaml, drift-gate.yaml on push/PR.")

  Rel(maintainer, tooling, "python tools/verify.py verify")
  Rel(maintainer, roles, "Develops roles")
  Rel(terraform_caller, reusable_wf, "uses: (pinned SHA)", "workflow_call")
  Rel(packer_caller, reusable_wf, "uses: (pinned SHA)", "workflow_call")
  Rel(reusable_wf, roles, "ansible-playbook site.yml")
  Rel(consumer_role, framework, "mirrors baseline-manifest.json files")
  Rel(github_actions, tooling, "python tools/verify.py verify")
